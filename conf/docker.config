// Docker profile: one pinned biocontainer per process.
//
// Pins are by FULL tag including the conda build hash (verified live on
// quay.io/biocontainers). The build hash makes the image reproducible AND means
// Nextflow pulls a finished layer instead of re-solving an env -> no solver
// lockups, no image balloon. Shared with SVcaller's verified bwa-mem2/samtools
// pins. If a tool lacks a helper (e.g. bwa-mem2 has no samtools), add a separate
// process with its own single-tool container rather than fattening one image.

docker {
    enabled    = true
    runOptions = '--rm -v /data/alvin/tmp:/tmp'
}

process {
    withName: 'BWAMEM2_MEM'   { container = 'quay.io/biocontainers/bwa-mem2:2.2.1--he70b90d_8' }
    withName: 'SAMTOOLS_.*'   { container = 'quay.io/biocontainers/samtools:1.23.1--ha83d96e_0' }
    withName: 'FGBIO_.*'      { container = 'quay.io/biocontainers/fgbio:4.1.0--hdfd78af_0' }
    withName: 'GATK4_.*'      { container = 'quay.io/biocontainers/gatk4:4.6.2.0--py310hdfd78af_1' }
    withName: 'PICARD_.*'     { container = 'quay.io/biocontainers/picard:3.4.0--hdfd78af_0' }
    withName: 'VEP'           { container = 'quay.io/biocontainers/ensembl-vep:116.0--pl5321h2a3209d_0' }
    withName: 'CNVKIT'        { container = 'quay.io/biocontainers/cnvkit:0.9.13--pyhdfd78af_0' }
    withName: 'PURPLE'        { container = 'quay.io/biocontainers/hmftools-purple:4.4--hdfd78af_0' }
    withName: 'FACETS'        { container = 'quay.io/biocontainers/cnv_facets:0.16.1--py312r43h8537716_1' }
    withName: 'PYCLONEVI'     { container = 'quay.io/biocontainers/pyclone-vi:0.2.0--pyhdfd78af_0' }

    // Custom Python engine + lightweight CLI helpers -> the one custom image.
    withName: 'PANEL_SELECT|INTERROGATE|MRD_INTEGRATE|BUILD_BACKGROUND|BUILD_PANEL|VALIDATE' {
        container = params.utils_container
    }
}
