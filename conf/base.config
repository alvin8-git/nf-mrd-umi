// Resource labels and the default container (the custom engine image, used by
// the glue/Python steps). Per-tool containers are assigned in conf/docker.config.

process {
    container = params.utils_container

    withLabel: process_low    { cpus = 2;  memory = 8.GB;  time = 4.h  }
    withLabel: process_medium { cpus = 8;  memory = 32.GB; time = 8.h  }
    withLabel: process_high   { cpus = 16; memory = 64.GB; time = 24.h }

    errorStrategy = 'retry'
    maxRetries    = 1
}
