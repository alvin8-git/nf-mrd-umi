// nf-mrd-umi Nextflow config.
//
// Container strategy mirrors github.com/alvin8-git/SVcaller: ONE pinned public
// biocontainer per process, never a monolithic conda image. A fat multi-tool
// conda image is what causes mamba solver lockups (it re-solves a huge
// dependency graph) and balloons image size; per-tool biocontainers ship a
// finished layer where the solve already happened upstream. A custom slim
// image is built ONLY for the parts not in biocontainers (the Python engine).
// Conda is a `local` fallback profile, never the default.

manifest {
    name            = 'nf-mrd-umi'
    description      = 'Tumor-informed ctDNA MRD pipeline'
    mainScript       = 'main.nf'
    nextflowVersion  = '>=23.04.0'
}

params {
    // Custom engine image (Python numpy/scipy/pysam + bin/). See Dockerfile.utils.
    utils_container = 'mrd-umi/utils:1.0'
}

includeConfig 'conf/base.config'

profiles {
    docker { includeConfig 'conf/docker.config' }
    local  { includeConfig 'conf/local.config'  }
    test   { includeConfig 'conf/test.config'   }
}
